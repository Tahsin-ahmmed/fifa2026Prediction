# ====================================================
# FIFA World Cup 2026 Predictor — Environment Variables
# ====================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git (it's already in .gitignore).
#
# How to get these values:
#   1. Go to https://supabase.com and create a free project
#   2. Go to Project Settings → API
#   3. Copy "Project URL" → NEXT_PUBLIC_SUPABASE_URL
#   4. Copy "anon public" key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# ====================================================

# Your Supabase project URL
# Example: https://abcdefghij.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Your Supabase anonymous (public) key — safe to expose in browser
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ====================================================
# NOTE: If these values are missing or contain "mock",
# the app will automatically fall back to demo/mock data.
# This means the app works perfectly even without Supabase!
# ====================================================
